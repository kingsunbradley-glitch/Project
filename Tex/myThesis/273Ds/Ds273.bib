@article{Hofmann2002,
  title = {New Results on Elements 111 and 112},
  author = {Hofmann, S. and He{\ss}berger, F.P. and Ackermann, D. and M{\"u}nzenberg, G. and Antalic, S. and Cagarda, P. and Kindler, B. and Kojouharova, J. and Leino, M. and Lommel, B. and Mann, R. and Popeko, A.G. and Reshitko, S. and {\'S}aro, S. and Uusitalo, J. and Yeremin, A.V.},
  year = 2002,
  month = jun,
  journal = {The European Physical Journal A},
  volume = {14},
  number = {2},
  pages = {147--157},
  issn = {1434-6001, 1434-601X},
  doi = {10.1140/epja/i2001-10119-x},
  urldate = {2025-09-19},
  abstract = {Experiments on the synthesis and identification of the nuclei 272111 and 277112 were performed in order to confirm previous results. Three additional decay chains were measured in the reaction 64Ni + 209Bi {$\rightarrow$} 273111{$\ast$}. The study revealed considerably improved data on the decay chain originating from 272111. One additional chain was measured in the reaction 70Zn + 208Pb {$\rightarrow$} 278112{$\ast$}. The decay properties of the chain starting at 277112 are in excellent agreement with the second chain of the first experiment down to 265Sg, where the new chain ends by a previously unknown spontaneous-fission branch. A re-analysis of all the data on elements 110, 111, and 112 measured at GSI since 1994 (a total of 34 decay chains was investigated) revealed that for 2 chains (the second chain of 269110 measured in 1994 and the first chain of 277112 measured in 1996) the results of the new analysis differed from the previous one. In all other cases the earlier data are exactly reproduced.},
  copyright = {http://www.springer.com/tdm},
  langid = {english},
  file = {/Users/evalie/Zotero/storage/JUBQ4DQG/Hofmann 等 - 2002 - New results on elements 111 and 112.pdf;/Users/evalie/Zotero/storage/UUFDQENK/Hofmann_等_-_2002_-_New_results_on_elements_111_and_112_2025-10-11 16_10_05.pdf}
}
