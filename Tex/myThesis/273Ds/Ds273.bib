  issn = {0939-7922},
  doi = {10.1007/BF02769517},
  abstract = {The new element 112 was produced and identified unambiguously in an experiment at SHIP, GSI Darmstadt. Two decay chains of the isotope277112 were observed in irradiations of208Pb targets with70Zn projectiles of 344 MeV kinetic energy. The isotope decays by emission of {$\alpha$} particles with a half-life of (240-90+430)\textmu s. Two different {$\alpha$} energies of (11,649\textpm 20) keV and (11,454\textpm 20) keV were measured for the two observed decays. The cross-section measured in three weeks of irradiations is (1.0-0.4+1.8) pb.},
