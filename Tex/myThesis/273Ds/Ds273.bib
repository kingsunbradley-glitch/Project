@article{Oganessian2022,
  title = {{{DGFRS-2}}---{{A}} Gas-Filled Recoil Separator for the {{Dubna Super Heavy Element Factory}}},
  author = {Oganessian, {\relax Yu.Ts}. and Utyonkov, V.K. and Popeko, A.G. and Solovyev, D.I. and Abdullin, {\relax F.Sh}. and Dmitriev, S.N. and Ibadullayev, D. and Itkis, M.G. and Kovrizhnykh, N.D. and Kuznetsov, D.A. and Petrushkin, O.V. and Podshibiakin, A.V. and Polyakov, A.N. and Sagaidak, R.N. and Schlattauer, L. and Shirokovsky, I.V. and Shubin, V.D. and Shumeiko, M.V. and Tsyganov, {\relax Yu.S}. and Voinov, A.A. and Subbotin, V.G. and Bekhterev, V.V. and Belykh, N.A. and Chernyshev, O.A. and Gikal, K.B. and Ivanov, G.N. and Khalkin, A.V. and Konstantinov, V.V. and Osipov, N.F. and Paschenko, S.V. and Protasov, A.A. and Semin, V.A. and Sorokoumov, V.V. and Sychev, K.P. and Verevochkin, V.A. and Yakovlev, B.I. and Antoine, S. and Beeckman, W. and Jehanno, P. and Yavor, M.I. and Shcherbakov, A.P. and Rykaczewski, K.P. and King, T.T. and Roberto, J.B. and Brewer, N.T. and Grzywacz, R.K. and Gan, Z.G. and Zhang, Z.Y. and Huang, M.H. and Yang, H.B.},
  year = 2022,
  month = jun,
  journal = {Nuclear Instruments and Methods in Physics Research Section A: Accelerators, Spectrometers, Detectors and Associated Equipment},
  volume = {1033},
  pages = {166640},
  issn = {01689002},
  doi = {10.1016/j.nima.2022.166640},
  urldate = {2025-11-15},
  abstract = {The main goal of development of the new Dubna Gas-Filled Recoil Separator (DGFRS-2) is to sufficiently improve the efficiency of studies on heavy and superheavy nuclei at the Super Heavy Element Factory of the Flerov Laboratory of Nuclear Reactions (FLNR) at the Joint Institute for Nuclear Research. The use of beams with the intensity up to 6 \texttimes{} 1013 s-1 (10 p{$\mu$}A) delivered by the DC280 cyclotron requires an effective setup providing high suppression of background reaction products. The described gas-filled separator is optimized for synthesis and study of heavy isotopes produced in complete fusion reactions of massive nuclei. Basic characteristics of DGFRS-2, as well as the results of the first test experiments, are presented. In comparison to the DGFRS-1, the transmission efficiency was doubled, and the background was reduced by a factor 200.},
  langid = {english},
  file = {/Users/evalie/Zotero/storage/C6ENC85X/Oganessian 等 - 2022 - DGFRS-2—A gas-filled recoil separator for the Dubna Super Heavy Element Factory.pdf}
}
@article{Hofmann2018,
  title = {On the Discovery of New Elements ({{IUPAC}}/{{IUPAP Provisional Report}}): {{Provisional Report}} of the 2017 {{Joint Working Group}} of {{IUPAC}} and {{IUPAP}}},
  shorttitle = {On the Discovery of New Elements ({{IUPAC}}/{{IUPAP Provisional Report}})},
  author = {Hofmann, Sigurd and Dmitriev, Sergey N. and Fahlander, Claes and Gates, Jacklyn M. and Roberto, James B. and Sakai, Hideyuki},
  year = 2018,
  month = nov,
  journal = {Pure and Applied Chemistry},
  volume = {90},
  number = {11},
  pages = {1773--1832},
  issn = {1365-3075, 0033-4545},
  doi = {10.1515/pac-2018-0918},
  urldate = {2025-11-15},
  abstract = {Almost thirty years ago the criteria that are currently used to verify claims for the discovery of a new element were set down by the comprehensive work of a Transfermium Working Group, TWG, jointly established by IUPAC and IUPAP. The recent completion of the naming of the 118 elements in the first seven periods of the Periodic Table of the Elements was considered as an opportunity for a review of these criteria in the light of the experimental and theoretical advances in the field. In late 2016 the Unions decided to establish a new Joint Working Group, JWG, consisting of six members determined by the Unions. A first meeting of the JWG was in May 2017. One year later this report was finished. In a first part the works and conclusions of the TWG and the Joint Working Parties, JWP, deciding on the discovery of the now named elements are summarized. Possible experimental developments for production and identification of new elements beyond the presently known ones are estimated. Criteria and guidelines for establishing priority of discovery of these potential new elements are presented. Special emphasis is given to a description for the application of the criteria and the limits for their applicability.},
  copyright = {http://creativecommons.org/licenses/by-nc-nd/4.0},
  langid = {english},
  keywords = {/unread},
  file = {/Users/evalie/Zotero/storage/5KL69XXJ/Hofmann 等 - 2018 - On the discovery of new elements (IUPACIUPAP Provisional Report) Provisional Report of the 2017 Jo.pdf}
}
