@article{Kuznetsova2023,
	abstract = {The GRAND gas-filled separator was created in the Flerov Laboratory of Nuclear Reactions (Joint Institute for Nuclear Research, Dubna) as a development of the experimental part of the Superheavy Element Factory. It is designed for synthesizing superheavy elements and studying their physical and chemical properties. Ion-optical parameters of the setup are checked by tracking α-particles from standard 226Ra and 244Cm sources. The effectiveness of the transport of recoil nuclei by the separator is estimated using the complete fusion reaction 208Pb(48Ca, xn)256No*.},
