@article{Alexandre1970,
	abstract = {Separations of rubidium, xenon and mercury are described. We discuss how to reduce ``gas contamination''. A high efficiency gas collector which has been used for several tens of milligrammes, is described. The mercury collector, derived from the xenon collector, is such that ``gas contamination'' can be totally avoided. A figure of merit of our separator is obtained plotting those enhancement factors which are not affected by ``gas contamination'' versus the relative mass difference.},
	author = {K. Alexandre and J. Camplan and M. Ligonniere and R. Meunier and J.L. Sarrouy and H.J. Smith and B. Vassent},
