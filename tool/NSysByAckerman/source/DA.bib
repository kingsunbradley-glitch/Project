@article{Zhang2014,
	abstract = {The global dynamical correlation energies for 575 even-even nuclei with proton numbers ranging from Z = 8 to Z = 108 calculated with the covariant density functional theory using the PC-PK1 parametrization are presented. The dynamical correlation energies include the rotational correction energies obtained with the cranking approximation and the quadrupole vibrational correction energies. The systematic behavior of the present correlation energies is in good agreement with that obtained from the projected generator coordinate method using the SLy4 Skyrme force although our values are systematically smaller. After including the dynamical correlation energies, the root-mean-square deviation predicted by the PC-PK1 for the 575 even-even nuclei masses is reduced from 2.58 MeV to 1.24 MeV.},
	author = {Zhang, Qian-Shun and Niu, Zhong-Ming and Li, Zhi-Pan and Yao, Jiang-Ming and Meng, Jie},
	doi = {10.1007/s11467-014-0413-5},
	issn = {2095-0470},
	journal = {Frontiers of Physics},
	number = {4},
	pages = {529--536},
	title = {Global dynamical correlation energies in covariant density functional theory: Cranking approximation},
	url = {http://dx.doi.org/10.1007/s11467-014-0413-5},
	volume = {9},
	year = {2014},
