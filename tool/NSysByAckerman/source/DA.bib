@article{Forge2023a,
	abstract = {The structure of the  nucleus has been studied for more than 20 years: the last publications on its decay spectroscopy are from LBNL [1], GSI [2], JYFL [3] and ANL [4]. Four decay schemes featuring two isomers have been published and are interpreted differently in terms of excitation energy and decay scheme of the 2 nd  isomer and configuration assignments of both K-isomers. These discrepancies have triggered new experiments including this one, performed with the GABRIELA [5, 6] array, at the focal plane of the SHELS [7] separator at the FLNR, Dubna. The first part of this proceeding will present the experimental setup and the analysis techniques used to reveal the electromagnetic decay of the known isomers in 254No. The second part will focus on the new results obtained with more than 1 million 254No nuclei implanted in the focal plane detector. In particular, the internal conversion electron spectrum observed in the decay of the 8− K-isomer has revealed the presence of a strong transition, most likely E0, suggesting low-lying shape coexistence in this nucleus as predicted in [8, 9]. The γ-ray spectrum obtained from the decay of the short-lived 170 μs isomer has revealed new γ-ray lines putting in doubt the previous interpretations about this isomer decay.},
	author = {M. Forge and O. Dorvaux and A. Lopez-Martens and K. Kessaci and B.J.P. Gall and K. Hauschild and Z. Asfari and R. Chakma and A.V. Yeremin and M.L. Chelnokov and V.I. Chepigin and A.V. Isaev and I.N. Izosimov and D. Katrasev and A.A. Kuznetsova and O.N. Malyshev and R. Mukhin and A.G. Popeko and Yu.A. Popov and A.I. Svirikhin and E.A. Sokol and M.S. Tezekbayeva and J. Piot},
	date-added = {2024-12-30 00:08:10 +0100},
	date-modified = {2024-12-30 00:08:28 +0100},
	doi = {10.1088/1742-6596/2586/1/012083},
	journal = {Journal of Physics: Conference Series},
	month = {sep},
	number = {1},
	pages = {012083},
	publisher = {IOP Publishing},
	title = {New results on the decay spectroscopy of 254No with GABRIELA@SHELS},
	url = {https://dx.doi.org/10.1088/1742-6596/2586/1/012083},
	volume = {2586},
	year = {2023},
	bdsk-url-1 = {https://dx.doi.org/10.1088/1742-6596/2586/1/012083}}

