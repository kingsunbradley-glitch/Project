@article{Ton1970ChT,
	abstract = {The lifetimes of the 2+ rotational states in 228Th, 234, 236U, 238,
	240Pu and 248Cm and of the 4+ rotational states in 228Th and 236U
	have been measured using the delayed coincidence technique. From
	the 2+ lifetimes the quantities B(E2; 2+ → 0+), Qo and β are derived
	and compared with theoretical predictions. The values of the ratio
	B(E2; 4+ → 2+)/B(E2; 2+ → 0+) in 228Th and 236U are found to
	be 1.42$\pm$0.16 and 1.27$\pm$0.16, respectively, in good agreement with
	the rotational-model prediction.},
	author = {H. Ton and W. Beens and S. Roodbergen and J. Blok},
	doi = {http://dx.doi.org/10.1016/0375-9474(70)90088-6},
	issn = {0375-9474},
	journal = {Nuclear Physics A},
	keywords = {Radioactivity},
	number = {1},
	pages = {235 - 244},
	title = {Lifetimes of 2+ and 4+ rotational states in heavy doubly even nuclei},
	url = {http://www.sciencedirect.com/science/article/pii/0375947470900886},
	volume = {155},
	year = {1970},
	bdsk-url-1 = {http://www.sciencedirect.com/science/article/pii/0375947470900886},
