@article{Adamian2016,
	abstract = {Properties and stability of superheavy nuclei resulting from hot fusion are discussed. It is shown that the microscopic--macroscopic approach allows obtaining the closed proton shell at Z ≥120. Isotopic trends of K-isomeric states in superheavy nuclei are predicted. Evaporation residue cross sections in hot fusion reactions are calculated using the predicted properties of superheavy nuclei. Interruption of αdecay chains by spontaneous fission is analyzed. Alpha decay chains through isomeric states are considered. Internal level densities in superheavy nuclei are microscopically calculated.},
