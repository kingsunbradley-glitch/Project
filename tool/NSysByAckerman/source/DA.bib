@article{Poenaru2007,
	abstract = {A new version of the semiempirical formula based on fission approach
	of alpha decay is derived, by using the optimum values of the fitting
	parameters determined for even-even nuclei, combined with hindrance
	factors for even-odd, odd-even, and odd-odd nuclides. The deviations
	from experimental data for two regions of nuclear chart (493 alpha
	emitters with Z =52--118 and 142 transuranium nuclei including superheavies
	( Z =92--118), respectively) are compared with those obtained by
