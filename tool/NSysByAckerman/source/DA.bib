@article{Duellmann2003,
	abstract = {Recently, the first successful chemical investigation of element 108, hassium (Hs) has been reported {$[$}1{$]$}. Based on 7 detected atoms, Hs was shown to form a higly volatile oxide, most probably HsO4. Therefore it behaves similarly to Os, which is known to form highly volatile OsO4. The enthalpies of adsorption-ΔHaO(T) of the compounds on silicon nitride were evaluated as (46$\pm$2) kJ/mol for HsO4, compared to (39$\pm$1) kJ/mol for OsO4 under identical experimental conditions. Hs should therefore be considered as a member of group 8 of the periodic table.},
	author = {D{\"u}llmann, Ch. E. and Dressler, R. and Eichler, B. and G{\"a}ggeler, H. W. and Glaus, F. and Jost, D. T. and Piguet, D. and Soverna, S. and T{\"u}rler, A. and Br{\"u}chle, W. and Eichler, R. and J{\"a}ger, E. and Pershina, V. and Sch{\"a}del, M. and Schausten, B. and Schimpf, E. and Sch{\"o}tt, H. -J. and Wirth, G. and Eberhardt, K. and Th{\"o}rle, P. and Trautmann, N. and Ginter, T. N. and Gregorich, K. E. and Hoffman, D. C. and Kirbach, U. W. and Lee, D. M. and Nitsche, H. and Patin, J. B. and Sudowe, R. and Zielinski, P. M. and Timokhin, S. N. and Yakushev, A. B. and Vahle, A. and Qin, Z.},
