	doi = {10.1140/epja/s10050-022-00707-9},
	id = {Tezekbayeva2022},
	isbn = {1434-601X},
	journal = {The European Physical Journal A},
	number = {3},
	pages = {52},
	title = {Study of the production and decay properties of neutron-deficient nobelium isotopes},
	url = {https://doi.org/10.1140/epja/s10050-022-00707-9},
	volume = {58},
	year = {2022},
	bdsk-url-1 = {https://doi.org/10.1140/epja/s10050-022-00707-9}}

