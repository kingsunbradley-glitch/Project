@article{Fields1967,
	abstract = {Alpha decay of the 39.3 h 254mEs isomer was observed and further studies showed that this decay populates a 2−excited state in 250Bk, but decay to the 2−ground state is highly hindered. The partial alpha half-life of 254mEs is 1.52$\pm$0.1 y. A lower limit to the spontaneous fission half-life of 254Es was set at 2.5 ×107 y. The total decay and partial spontaneous fission half-lives of 254Fm were redetermined as 194.4$\pm$0.1 min and 228$\pm$1 d, respectively. The pile neutron cross sections of 253Es to produce the two isomers of 254Es were measured as σc = 13 b (254Es), σc = 338 b (254mEs). The partial alpha half-life of 255Es has been measured as 1.38$\pm$0.08 y and the partial spontaneous fission half-life as 2440$\pm$140 y. The rotational band structure observed in the alpha decay of 255Es is consistent with a 72+ spin.},
	author = {Fields, P. R. and Diamond, H. and Friedman, A. M. and Milsted, J. and Lerner, J. L. and Barnes, R. F. and Sjoblom, R. K. and Metta, D. N. and Horwitz, E. P.},
