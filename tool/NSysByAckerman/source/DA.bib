@article{Galkina2021,
	abstract = {The mass-energy distributions of fragments of the reaction 32S + 232Th leading to the formation of 264Sg (Z = 106) at energies of incident ions 32S of 165, 181 and 200 MeV are measured. The contribution from the quasifission process is found at energies below and above the Coulomb barrier in the region of symmetric masses (АCN/2 $\pm$20). A high-energy symmetric fission mode is found at an energy of 165 MeV, which corresponds to the excitation energy of the compound 264Sg nucleus 45 MeV.},
