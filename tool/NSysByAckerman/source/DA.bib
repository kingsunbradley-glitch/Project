	journal = {Journal of the Less Common Metals},
	note = {Proceedings of Actinides 85 - Part 2},
	pages = {445-451},
	title = {Experiments on the synthesis of neutron-deficient isotopes with atomic numbers in the region from Z = 102 to Z = 105},
	url = {https://www.sciencedirect.com/science/article/pii/0022508886904406},
	volume = {122},
