@article{Wang2012,
	abstract = {It has been found that high-order deformation (e.g. $\beta$ 6) can
	have important effects on the structures of superheavy nuclei. In
	the present work, we investigate octupole deformation effects on
	superheavy nuclei with an improved potential-energy-surface (PES)
	calculation by including reflection-asymmetric deformations in a
	space of ($\beta$ 2, $\beta$ 3, $\beta$ 4, $\beta$ 5). The calculations
	give various deformations including highly deformed ($\beta$ 2 ≈
	0.4) and superdeformed ($\beta$2 ≈ 0.7) shapes. The octupole-deformation
	degree of freedom mainly affects the fission barrier beyond the second
	minimum of PES.},
	author = {Wang, HuaLei and Liu, HongLiang and Xu, FuRong and Jiao, ChangFeng},
	date-modified = {2021-06-30 17:43:14 +0000},
	doi = {10.1007/s11434-012-5118-y},
