@article{Khuyagbaatar2008,
	abstract = {Spontaneous fission of neutron-deficient fermium isotopes (N ≤144) was investigated. The nuclei were produced in fusion-evaporation reactions of 40Ar beams with 204,206--208Pb targets. Excitation functions of the two-and three-neutron evaporation channels were measured. The new isotope 241Fm was identified, and its decay properties were determined. A previously made assignment of a 0.8 ms spontaneous-fission activity to the isotope 242Fm could not be confirmed. Isomeric states were not observed in any of the investigated isotopes. The experiments were performed at the velocity filter SHIP of GSI in Darmstadt.},
