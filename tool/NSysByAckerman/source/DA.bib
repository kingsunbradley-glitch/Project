@article{Antalic2010,
	abstract = {The radioactive decay of the isotopes 247Md , 246Md and their daughter
	products was investigated by means of {\$} {\backslash}alpha{\$}
	- {\$} {\backslash}alpha{\$} and {\$} {\backslash}alpha{\$} - {\$}
	{\backslash}gamma{\$} coincidence spectroscopy. The isotopes were
	produced using the fusion reaction 40Ar{\$} + {\$}209Bi. Decay schemes
	are suggested for 247Md and 243Es . A new isomeric state in 246Md
	with a half-life of ( 4.4{\textpm}0.8 s was observed. Previous data
	of electron-capture delayed fission of 246Md and 242Es were confirmed.
	The probability for this decay branch in 246Md was measured to be
