@article{Forsberg2016,
	abstract = {Products of the fusion-evaporation reaction 48Ca + 243Am were studied with the TASISpec set-up at the gas-filled separator TASCA at the GSI Helmholtzzentrum f{\"u}r Schwerionenforschung, Darmstadt, Germany. Amongst the detected thirty correlated α-decay chains associated with the production of element Z=115, two recoil-α-fission and five recoil-α--α-fission events were observed. The latter five chains are similar to four such events reported from experiments performed at the Dubna gas-filled separator, and three such events reported from an experiment at the Berkeley gas-filled separator. The four chains observed at the Dubna gas-filled separator were assigned to start from the 2n-evaporation channel 289115 due to the fact that these recoil-α--α-fission events were observed only at low excitation energies. Contrary to this interpretation, we suggest that some of these recoil-α--α-fission decay chains, as well as some of the recoil-α--α-fission and recoil-α-fission decay chains reported from Berkeley and in this article, start from the 3n-evaporation channel 288115.},
	author = {U. Forsberg and D. Rudolph and L.-L. Andersson and A. {Di Nitto} and Ch.E. D\"{u}llmann and C. Fahlander and J.M. Gates and P. Golubev and K.E. Gregorich and C.J. Gross and R.-D. Herzberg and F.P. He{\ss}berger and J. Khuyagbaatar and J.V. Kratz and K. Rykaczewski and L.G. Sarmiento and M. Sch\"{a}del and A. Yakushev and S. Aberg and D. Ackermann and M. Block and H. Brand and B.G. Carlsson and D. Cox and X. Derkx and J. Dobaczewski and K. Eberhardt and J. Even and J. Gerl and E. J{\"a}ger and B. Kindler and J. Krier and I. Kojouharov and N. Kurz and B. Lommel and A. Mistry and C. Mokry and W. Nazarewicz and H. Nitsche and J.P. Omtvedt and P. Papadakis and I. Ragnarsson and J. Runke and H. Schaffner and B. Schausten and Yue Shi and P. Th{\"o}rle-Pospiech and T. Torres and T. Traut and N. Trautmann and A. T{\"u}rler and A. Ward and D.E. Ward and N. Wiehl},
	date-added = {2021-08-20 15:56:53 +0000},
	date-modified = {2021-10-13 14:03:52 +0000},
	doi = {https://doi.org/10.1016/j.nuclphysa.2016.04.025},
