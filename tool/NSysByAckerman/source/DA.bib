	doi = {http://dx.doi.org/10.1016/j.physletb.2014.07.062},
	issn = {0370-2693},
	journal = {Physics Letters B},
	keywords = {Fusion-by-diffusion model},
	pages = {478 - 481},
	title = {No chance for synthesis of super-heavy nuclei in fusion of symmetric systems},
	url = {http://www.sciencedirect.com/science/article/pii/S0370269314005656},
	volume = {736},
	year = {2014},
	bdsk-url-1 = {http://www.sciencedirect.com/science/article/pii/S0370269314005656},
	bdsk-url-2 = {http://dx.doi.org/10.1016/j.physletb.2014.07.062}}

