@article{Cocks1999,
	abstract = {High-spin spectroscopy of Rn, Ra and Th isotopes has been performed.
	The nuclei have been populated using multi-nucleon transfer reactions
	involving a 232Th target and a 136Xe projectile. This type of reaction
	offers the only mechanism for populating high-spin states in many
	of these nuclei. Interleaving bands with opposite parities have been
	observed to high spin (∼28h̵) in 218,220,222Rn, 222,224,226,228Ra
	and 228,230,234Th. A systematic study of the rotational alignment
	properties of octupole bands in radon, radium and thorium isotopes
	reveals information concerning the role of the octupole phonon and
	the onset of stable octupole deformation with increasing rotational
	frequency. Measurement of the magnitude of the intrinsic electric
	dipole moment, D0, provides additional information concerning the
	strength of octupole interactions in these nuclei.},
	author = {J.F.C. Cocks and D. Hawcroft and N. Amzal and P.A. Butler and K.J. Cann and P.T. Greenlees and G.D. Jones and S. Asztalos and R.M. Clark and M.A. Deleplanque and R.M. Diamond and P. Fallon and I.Y. Lee and A.O. Macchiavelli and R.W. MacLeod and F.S. Stephens and P. Jones and R. Julin and R. Broda and B. Fornal and J.F. Smith and T. Lauritsen and P. Bhattacharyya and C.T. Zhang},
	date-modified = {2024-01-10 10:20:02 +0100},
	doi = {http://dx.doi.org/10.1016/S0375-9474(98)00586-7},
	issn = {0375-9474},
	journal = {Nuclear Physics A},
	keywords = {\{NUCLEAR\} \{REACTIONS\} 232Th(136Xe, X), E = 833 MeV},
	number = {1},
	pages = {61 - 91},
	title = {Spectroscopy of Rn, Ra and Th isotopes using multi-nucleon transfer reactions},
	url = {http://www.sciencedirect.com/science/article/pii/S0375947498005867},
	volume = {645},
	year = {1999},
	bdsk-url-1 = {http://www.sciencedirect.com/science/article/pii/S0375947498005867},
	bdsk-url-2 = {http://dx.doi.org/10.1016/S0375-9474(98)00586-7}}

@article{Cocks2000,
	//author = {J F C Cocks and P A Butler and K J Cann and P T Greenlees and G D Jones and J F Smith and P M Jones and R Julin and S Juutinen and D M{\~A}¼ller and M Piiparinen and A Savelius and R Broda and B Fornal and I Ahmad and D J Blumenthal and M P Carpenter and B Crowell and R V F Janssens and T L Khoo and T Lauritsen and D Nisius and S Asztalos and R M Clark and M A Deleplanque and R M Diamond and P Fallon and I Y Lee and A O Macchiavelli and R W MacLeod and F S Stephens and P Bhattacharyya and C T Zhang},
	abstract = {Multi-nucleon transfer reactions have been shown to be an important
	tool for high-spin spectroscopic studies of Rn, Ra and Th nuclei
	with N ##IMG## [http://ej.iop.org/icons/common/simeq.gif] {simeq}
	134. These nuclei have been populated using the heavy-ion collisions
	of 56 Fe+ 232 Th, 86 Kr+ 232 Th and 136 Xe+ 232 Th at beam energies
	15-20% above the Coulomb barrier. Excited states with spins as high
	as 28 ##IMG## [http://ej.iop.org/icons/common/hbar.gif] {hbar} have
	been observed using the latter reaction. Yield distributions of binary-reaction
	products stopped in thick targets have been derived from the analysis
	of ##IMG## [http://ej.iop.org/icons/common/gamma.gif] {gamma} - ##IMG##
	[http://ej.iop.org/icons/common/gamma.gif] {gamma} and ##IMG## [http://ej.iop.org/icons/common/gamma.gif]
	{gamma} - ##IMG## [http://ej.iop.org/icons/common/gamma.gif] {gamma}
	- ##IMG## [http://ej.iop.org/icons/common/gamma.gif] {gamma} coincidence
	events. These yields indicate that there is significant fission of
	the target-like reaction products. Intensities deduced for products
	resulting from neutron transfer or proton transfer appear to be Q
	-value dependent, while processes involving transfers of several
	protons and neutrons are governed by mass and charge equilibration.},
