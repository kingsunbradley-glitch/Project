@article{Rodin2014,
	abstract = {The MASHA mass spectrometer designed for identifying superheavy elements by their masses is described. The separation efficiency has been measured in the autonomous mode using four calibrated leakages of noble gases. The total separation efficiency of the mass spectrometer with a hot catcher and an ion source based on the electron cyclotron resonance has been determined using the 40Ar beam. Test experiments have been carried out, in which α-active Hg isotopes produced in complete fusion reaction 40Ar + 144Sm →184 −xnHg + xn, have been detected in the focal plane of the mass spectrometer. The separation time and efficiency have been determined for short-lived Hg isotopes.},
