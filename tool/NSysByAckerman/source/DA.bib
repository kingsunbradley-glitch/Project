@article{Metta1965,
	abstract = {The total half-lives of 252Cf, 250Cf, 253Cf are 2·646 $\pm$0·004 years, 13·2 $\pm$0·5 years and 17·6 $\pm$0·2 days. The ratios of α-emission to spontaneous fission for 252Cf, 250Cf, 253Es and 244Cm are 31·3 $\pm$0·2, 1260 $\pm$40, (1·15 $\pm$0·03)107 and (7·43 $\pm$0·01)105. The partial spontaneous fission half-life of 246Cm = (1·66 $\pm$0·10)107 years. The thermal neutron fission cross sections for 249Cf and 251Cf are 1735 $\pm$70 barns and 3000 $\pm$260 barns. A separate determination and a re-evaluation of the data from the MIKE thermonuclear event confirms the 60·5 $\pm$0·2 day 254Cf half-life reported by others.},
