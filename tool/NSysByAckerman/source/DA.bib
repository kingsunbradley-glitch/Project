@article{Flerov1971,
	abstract = {In bombardments of a 243Am target with 22Ne ions a spontaneous fission activity with a half-life of {ce:inline-formula}1.8$\pm$0.6s{/ce:inline-formula} has been observed. The yield corresponds to a formation cross section of {ce:inline-formula}(5.0$\pm$1.5) × 10 −34cm 2{/ce:inline-formula}, for the spontaneous fission decay. Integral angular distributions of products from the reaction 243Am + 22Ne and the formation cross section for the new isotope as a function of the bombarding ion energy have been measured. From these data and the results of test experiments it is concluded that the atomic number of the new spontaneous fission activity with {ce:inline-formula}T 1/2≈ 2s{/ce:inline-formula}, is 105. The spontaneous fission decay of the isotopes 256,257103 has also been investigated. The spontaneous fission half-lives of these nuclei are shown to be larger than 10 5 s.},
