@article{Nitschke1979,
	abstract = {Excitation functions for compound-nucleus and transfer reactions have
	been measured with 48Ca ions on 208Pb targets. A comparison is made
	with the 40Ar-on-208Pb reaction to explain the observed anomalous
	behavior of the transfer reactions and a surprising cutoff of the
	(48Ca, 3n) exit channel. The former effect is interpreted as an enhancement
	of the tunneling gap between the projectile and the target while
	the latter is seen as a consequence of the angular momentum of the
	compound nucleus.},
