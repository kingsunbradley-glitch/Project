	abstract = {In the present work, considering the blocking effect of unpaired nucleons and the orbital angular momentum taken away by the emitted {\$}{\$}{$\backslash$}alpha {\$}{\$}particle, we put forward an improved Geiger-Nuttall law to calculate {\$}{\$}{$\backslash$}alpha {\$}{\$}-decay half-lives of heavy and superheavy nuclei. There are three adjustable parameters in this formula, whose values are obtained by fitting experimental {\$}{\$}{$\backslash$}alpha {\$}{\$}decay half-lives of 216 nuclei ranging from Z = 90 to Z = 118 with N {\$}{\$}{$\backslash$}ge {\$}{\$}130 from the ground state and/or isomeric state. The calculated results are in good agreement with the experimental data. The corresponding root-mean-square (rms) are 0.301, 0.587 and 0.541 for 65 even--even, 116 odd-A and 35 odd--odd nuclei, respectively. For comparison, the Royer formula proposed by G. Royer {$[$}J. phys. G 26, 1149(2000){$]$}, Viola-Seaborg-Sobiczewski formula (VSS) proposed by A. Sobiczewski et al. {$[$}J. Inorg. Nucl. Chem 28, 741(1966){$]$} and Sobiczewski-Parkhomenko formula (SP) proposed by A. Parkhomenko et al. {$[$}Acta. Phys. Pol. B 36, 3095(2005){$]$} are also used. In addition, this improved formula is extended to predict {\$}{\$}{$\backslash$}alpha {\$}{\$}-decay half-lives for nuclei with Z = 117, 118, 119 and 120. The corresponding predictions of these formulae are basically consistent with each other.},
	author = {Luo, Song and Xu, Yang-Yang and Zhu, De-Xing and He, Biao and Chu, Peng-Cheng and Li, Xiao-Hua},
	date = {2022/12/14},
	date-added = {2024-10-29 04:43:11 +0100},
	date-modified = {2024-10-29 04:43:21 +0100},
	doi = {10.1140/epja/s10050-022-00898-1},
	id = {Luo2022},
	isbn = {1434-601X},
	journal = {The European Physical Journal A},
	number = {12},
	pages = {244},
	title = {Improved Geiger--Nuttall law for {\$}{\$}{$\backslash$}alpha {\$}{\$}-decay half-lives of heavy and superheavy nuclei},
	url = {https://doi.org/10.1140/epja/s10050-022-00898-1},
	volume = {58},
	year = {2022},
	bdsk-url-1 = {https://doi.org/10.1140/epja/s10050-022-00898-1}}

@article{Ismail2022,
	abstract = {Improved NRDX empirical formula for {\$}{\$}{$\backslash$}alpha {\$}{\$}- and cluster decay half-lives is modified by adding the effects of angular momentum, isospin asymmetry and parity. The coefficients are determined using the latest experimental data for {\$}{\$}{$\backslash$}alpha {\$}{\$}-decay half-lives of 573 nuclei and the available 22 cluster decay half-lives. The modified formulas produced the {\$}{\$}{$\backslash$}alpha {\$}{\$}- and cluster decay half-lives and agree with calculations of other similar formulas. We used the new formulas to calculate the half-lives of cluster emissions of the SHN with {\$}{\$}Z=120{\$}{\$}, 122, 124, and 126, which have not yet been experimentally synthesized.},
