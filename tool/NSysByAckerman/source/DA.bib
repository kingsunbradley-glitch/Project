@article{Vostinar2019,
	abstract = {The superheavy isotope 258Db was produced in the 209Bi(50Ti, 1n)258Db reaction at GSI, Germany. A detailed {\$} {$\backslash$}alpha{\$}α-spectroscopy study of this isotope and its {\$} {$\backslash$}alpha{\$}α-decay daughter products was performed. Two long-lived {\$} {$\backslash$}alpha{\$}α-decaying states in 258Db are observed. A spin-parity of {\$} 0\^{}{\{}-{\}}{\$}0- is tentatively assigned to the ground state for which a half-life of {\$} 2.17 {$\backslash$}pm 0.36{\$}2.17$\pm$0.36 s is determined. Spins and parities of either {\$} 5\^{}{\{}+{\}}{\$}5+ or {\$} 10\^{}{\{}-{\}}{\$}10- are proposed for the isomeric state found at an excitation energy of 51 keV with a half-life of {\$} 4.41 {$\backslash$}pm 0.21{\$}4.41$\pm$0.21 s. The {\$} {$\backslash$}alpha{\$}α-decay daughter isotope 254Lr displays a similar behavior. A half-life of {\$} 11.9 {$\backslash$}pm 0.9{\$}11.9$\pm$0.9 s is determined for the 254Lr ground state which is tentatively assigned a spin-parity of {\$} 4\^{}{\{}+{\}}{\$}4+. The isomeric level of this isotope placed at 108 keV with a half-life of {\$} 20.3 {$\backslash$}pm 4.2{\$}20.3$\pm$4.2 s is tentatively assigned a spin-parity of {\$} 1\^{}{\{}-{\}}{\$}1-. Two long-lived {\$} {$\backslash$}alpha{\$}α-decaying states are observed in the granddaughter isotope 250Md . The ground state has a half-life of {\$} 59.5 {$\backslash$}pm 9.1{\$}59.5$\pm$9.1 s. A half-life of {\$} 42.4 {$\backslash$}pm 4.5{\$}42.4$\pm$4.5 s is measured for the isomeric state positioned at an excitation energy of 123 keV. Partial, tentative level schemes for 254Lr, 250Md and 246Es are proposed based on the {\$} {$\backslash$}alpha{\$}α-{\$} {$\backslash$}gamma{\$}γcoincidences.},
	author = {Vostinar, M. and He{\ss}berger, F. P. and Ackermann, D. and Andel, B. and Antalic, S. and Block, M. and Droese, Ch. and Even, J. and Heinz, S. and Kalaninova, Z. and Kojouharov, I. and Laatiaoui, M. and Mistry, A. K. and Piot, J. and Savajols, H.},
	da = {2019/02/14},
	date-added = {2020-01-20 10:33:17 +0000},
