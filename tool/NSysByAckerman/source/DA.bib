@article{Ahmad1982,
	abstract = {The ?-decay scheme of 257Fm has been investigated by measuring the
	?-particle, electron and ?-ray spectra of several sources containing
	?1000 257Fm ?-disintegrations per minute. Five ?-groups were identified:
	6.756 MeV (0.60%), 6.695 MeV (3.5%), 6.520 MeV (93.6%), 6.441 MeV
	(2.0%) and 6.346 MeV (0.3%). ?-ray spectra were measured with Ge(Li)
	spectrometers and the intensity of the 179.4 keV ?-ray was found
	to be 8.7 $\pm$ 0.7 photons per 100 257Fm ?-decays. A conversion-electron
	spectrum was measured with a cooled Si(Li) detector and transition
	multipolarities were derived. On the basis of the present investigation
	the 253Cf ground state has been assigned to the 72+[613] single-particle
	state and the 257Fm ground state and the 241.0 keV state in 253Cf
	are assigned to the 92+[615] orbital. The ?-intensities and ?-ray
	branching ratios have been explained in terms of Coriolis mixing
	between the 72+[613] and 92+[615] states. Our observations are in
	agreement with the results of a previous study by Asaro and Perlman.},
	author = {Irshad Ahmad and E.Phillip Horwitz},
