	doi = {https://doi.org/10.1016/j.nima.2018.01.096},
	issn = {0168-9002},
	journal = {Nuclear Instruments and Methods in Physics Research Section A: Accelerators, Spectrometers, Detectors and Associated Equipment},
	keywords = {, , CE and X-ray spectroscopy, Si strip detector, Digital electronics, Large volume Ge detectors},
	note = {Advances in Instrumentation and Experimental Methods (Special Issue in Honour of Kai Siegbahn)},
	pages = {81-89},
