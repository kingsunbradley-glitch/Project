@article{Unik1962,
	abstract = {The beta decay of Es254 has been studied using gamma-gamma and beta-gamma scintillation coincidence techniques and a double-lens beta-ray spectrometer. Transitions of 103.5$\pm$1, 544$\pm$5, 583$\pm$3, 648$\pm$2 and 692$\pm$2 keV have been placed in a level scheme of Fm254 with levels at 44$\pm$3(2+,0), 148$\pm$3(4+,0), 692$\pm$2(2+,2) and 734$\pm$4(3+,2) keV. Two beta spectra of 475$\pm$5(75{\%}) and 1127$\pm$2(25{\%}) keV were observed. The observation of the (2+,2) gamma-vibrational state at 692 keV in FM254 indicates that there is a sharp decrease in the gamma-vibrational energy after 152 neutrons. A half-life of 39.3$\pm$0.2 h was obtained for the Es254 beta emitter. Transitions of 93$\pm$2, 377$\pm$3, 387$\pm$1 and 427$\pm$3 keV were observed from the alpha decay of Es253.},
	author = {Unik, J. and Day, P. and Vandenbosch, S.},
	da = {1962/06/01/},
