	issn = {0168-9002},
	journal = {Nuclear Instruments and Methods in Physics Research Section A: Accelerators, Spectrometers, Detectors and Associated Equipment},
	keywords = {Low pressure Multi-Wire Proportional Counter (MWPC), VAMOS++, Tracking of heavy reaction products, Doppler correction, Energies around the Coulomb barrier},
	pages = {112-117},
	title = {Dual Position Sensitive MWPC for tracking reaction products at VAMOS++},
