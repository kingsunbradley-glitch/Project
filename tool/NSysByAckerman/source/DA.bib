	isbn = {0370-2693},
	journal = {Physics Letters B},
	keywords = {Isotope shift; Nuclear charge radius; Potassium; Collinear laser spectroscopy},
	pages = {97--102},
	title = {Nuclear charge radii of potassium isotopes beyond N=28},
	ty = {JOUR},
	url = {http://www.sciencedirect.com/science/article/pii/S0370269314001038},
	volume = {731},
	year = {2014},
	bdsk-url-1 = {http://www.sciencedirect.com/science/article/pii/S0370269314001038},
