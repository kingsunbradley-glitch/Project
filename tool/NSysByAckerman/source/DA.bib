@article{Afanasjev2018,
	abstract = {Octupole deformed shapes in neutron-rich actinides and superheavy nuclei as well as extremely deformed shapes of the ##IMG## [http://ej.iop.org/images/1402-4896/93/3/034002/psaaa3d0ieqn1.gif] {$N\sim Z$} light nuclei have been investigated within the framework of covariant density functional theory. We confirmed the presence of new region of octupole deformation in neutron-rich actinides with the center around ##IMG## [http://ej.iop.org/images/1402-4896/93/3/034002/psaaa3d0ieqn2.gif] {$Z\sim 96,N\sim 196$} but our calculations do not predict octupole deformation in the ground states of superheavy ##IMG## [http://ej.iop.org/images/1402-4896/93/3/034002/psaaa3d0ieqn3.gif] {$Z\geqslant 108$} nuclei. As exemplified by the study of 36 Ar, the nodal structure of the wavefunction of occupied single-particle orbitals in extremely deformed structures allows to understand the formation of the ? -clusters in very light nuclei, the suppression of the ? -clusterization with the increase of mass number, the formation of ellipsoidal mean-field type structures and nuclear molecules.},
	author = {A V Afanasjev and H Abusara and S E Agbemava},
	date-modified = {2018-12-11 10:35:45 +0000},
	journal = {Physica Scripta},
	number = {3},
	pages = {034002},
	title = {Octupole deformation in neutron-rich actinides and superheavy nuclei and the role of nodal structure of single-particle wavefunctions in extremely deformed structures of light nuclei},
	url = {http://stacks.iop.org/1402-4896/93/i=3/a=034002},
	volume = {93},
	year = {2018},
	bdsk-url-1 = {http://stacks.iop.org/1402-4896/93/i=3/a=034002}}

