	issn = {0370-2693},
	journal = {Physics Letters B},
	keywords = {Nuclear reactions, Deep-inelastic collisions, Exotic nuclei},
	pages = {456-459},
	title = {Neutron-rich nuclei produced at zero degrees in damped collisions induced by a beam of 18O on a 238U target},
