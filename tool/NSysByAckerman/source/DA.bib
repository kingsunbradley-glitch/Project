@article{Sahm1985,
	abstract = {Cross sections were measured for the formation of evaporation residues in 48Ca-, 86Kr- and 124 Sn-induced reactions with Yb, Sb and Zr isotopes. For the nearly symmetric systems, the energy dependence of the fusion probability in central collisions was determined. The fusion probability at the expected fusion barrier as calculated from a one-dimensional heavy-ion potential was found to be reduced by several orders of magnitude. The fusion cross sections increase gradually, and only at energies appreciably above the expected fusion barrier the major part of the cross section of central collisions leads to fusion. The observed hindrance of the fusion process is compared with model predictions.},
	author = {C.C. Sahm and H.G. Clerc and K.-H. Schmidt and W. Reisdorf and P. Armbruster and F.P. Hessberger and J.G. Keller and G. M{\"u}nzenberg and D. Vermeulen},
