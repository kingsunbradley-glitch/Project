@article{Hoff1968,
	abstract = {The nuclide 256Fm was produced in 4He ion bombardment of a 3μg 253Es target. With samples where the fermium fraction was isolated chemically, the mass 256 was enriched in an electromagnetic isotope separator. The nuclear decay properties of 256Fm have been measured as follows: The half-life is 157$\pm$2 min. The alpha branching ratio is ζ/(ζ+SF) = 0.081$\pm$0.003, and the alpha-particle energy of the most abundant group is 6.925$\pm$0.005 MeV. The measured alpha-decay rate shows satisfactory agreement with a calculated value derived from theory. The cross section for the reaction 255Fm(n, γ)256Fm with well-modulated reactor neutrons has been measured and found to be 30$\pm$4 b.},
	author = {R.W. Hoff and J.E. Evans and E.K. Hulet and R.J. Dupzyk and B.J. Qualheim},
	date-added = {2021-08-10 16:32:12 +0000},
