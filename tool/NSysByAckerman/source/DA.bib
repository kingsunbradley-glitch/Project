@article{Weigmann1972,
	abstract = {A combined analysis of data from narrow intermediate structure in
	near-barrier fission cross sections and from shape-isomer half-lives
	has been tried in a very phenomenological model. Among the results,
	one observes a marked even-odd effect in the ħω values, whilst
	the barrier heights do not show a significant effect of this type.
	It seems that one of the most important open questions is whether
	or not narrow intermediate structure exists close to the neutron
