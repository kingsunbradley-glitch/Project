@article{Cwiok1994,
	abstract = {The status of experimental and theoretical studies of the heaviest
	elements is reviewed. The single-particle structure of the heaviest
	nuclei with 95$\leq$Z$\leq$111 and 149$\leq$N$\leq$162 is investigated
