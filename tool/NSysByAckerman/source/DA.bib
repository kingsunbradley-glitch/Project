@article{Ahmad2019,
	abstract = {Energies of α particles in the decay of heavy Es, Fm and Md isotopes were reevaluated by analyzing previously published and unpublished data. The α-particle spectra were measured in 1970s at the Argonne National Laboratory with a magnetic spectrometer and with silicon detectors using very thin, mass-separated sources. The new values for the α-particle energies were determined with respect to the precise values of 6632.51 $\pm$ 0.05 keV for the 253Es α0 group and 6118.10 $\pm$ 0.04 keV for the 252Cf α0 group, as well as those of 7040.0 $\pm$ 1.0 keV and 7022.0 $\pm$ 0.5 keV for the 252Fm α0 and 255Fm α106 groups, respectively, evaluated in the present work. The deduced uncertainties in the α-particle energies were reduced compared to earlier measurements.},
