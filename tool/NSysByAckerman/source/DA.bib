	doi = {https://doi.org/10.1016/0925-8388(94)90881-8},
	issn = {0925-8388},
	journal = {Journal of Alloys and Compounds},
	note = {International Conference on Actinides},
	pages = {61-66},
	title = {Observation of enhanced nuclear stability near the 162 neutron shell},
	url = {https://www.sciencedirect.com/science/article/pii/0925838894908818},
	volume = {213-214},
	year = {1994},
	bdsk-url-1 = {https://www.sciencedirect.com/science/article/pii/0925838894908818},
	bdsk-url-2 = {https://doi.org/10.1016/0925-8388(94)90881-8}}

