@article{Muntian2001,
	abstract = {Problem of experimental confirmation of deformed shapes predicted
	for superheavy nuclei situated around the nucleus 270Hs is discussed.
	Measurement of energy of only the first 2+ state, and not the observation
	of an extended rotational band, in even--even species of these nuclei
	is considered as a method for this confirmation. This energy is calculated
	in a multidimensional deformation space within the cranking approximation.
	Branching ratio between α decay of a nucleus to the 2+ state and
	to the 0+ ground state of its daughter is also calculated for the
	considered nuclei. The results indicate that the confirmation of
	deformed shapes of the nuclei is presently possible.},
