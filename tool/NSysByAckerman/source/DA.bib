@article{Patyk1991ChT,
	abstract = {The formation of the main deformed shells in heavy nuclei is studied
	in five-dimensional deformation space [βλ], λ=2, 4, 6, 8, 10.
	Nuclei with proton number Z=90−114 and neutron number N=136−168
	are considered. The ground-state energy of the nuclei is treated
	in the macroscopic-microscopic approach. Single-particle spectra
	are obtained with the Woods-Saxon potential. It is found that the
	calculated shells are convergent with the increasing size of the
	deformation space, with the maximum multi-polarity λmax=8 being
	sufficient to be included, for the nuclei considered. Role of separate
	multipolarities in the formation of the shells is discussed.},
