	keywords = {Recoil mass separator},
	note = {Proceedings of the {XVth} International Conference on Electromagnetic Isotope Separators and Techniques Related to their Applications},
	number = {19--20},
	pages = {4196 - 4200},
	title = {{The new vacuum-mode recoil separator MARA at JYFL}},
