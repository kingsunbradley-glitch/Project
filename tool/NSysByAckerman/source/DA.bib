@article{Dobaczewski2015,
	abstract = {Abstract We calculate properties of the ground and excited states
	of nuclei in the nobelium region for proton and neutron numbers of
	92 ≤ Z ≤ 104 and 144 ≤ N ≤ 156 , respectively. We use three
	different energy-density-functional (EDF) approaches, based on covariant,
	Skyrme, and Gogny functionals, each with two different parameter
	sets. A comparative analysis of the results obtained for quasiparticle
	spectra, odd--even and two-particle mass staggering, and moments
	of inertia allows us to identify single-particle and shell effects
	that are characteristic to these different models and to illustrate
	possible systematic uncertainties related to using the \{EDF\} modelling.},
	author = {J. Dobaczewski and A.V. Afanasjev and M. Bender and L.M. Robledo and Yue Shi},
	date-modified = {2019-07-24 12:01:35 +0000},
	doi = {http://dx.doi.org/10.1016/j.nuclphysa.2015.07.015},
	issn = {0375-9474},
	journal = {Nuclear Physics A},
	keywords = {Heavy and superheavy nuclei},
	note = {Special Issue on Superheavy Elements},
	pages = {388 - 414},
	title = {{Properties of nuclei in the nobelium region studied within the covariant, Skyrme, and Gogny energy density functionals}},
	url = {http://www.sciencedirect.com/science/article/pii/S0375947415001633},
	volume = {944},
