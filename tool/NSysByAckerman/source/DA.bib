@article{Staszczak1989,
	abstract = {The potential-energy surface and the mass parameters of the even-even
	transplutonium elements are evaluated. Our microscopic hamiltonian
	consists of the Nilsson potential, the two-body residual interaction
	in the local approximation and the pairing forces. The calculations
	are performed in the generator coordinate method with the extended
	gaussian-overlap approximation. The coupling of the pairing vibrations
	with the fission mode (elongation and neck) reduces the WKB estimates
	of the fission lifetimes by a few orders of magnitude.},
