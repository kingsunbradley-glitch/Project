@article{Hessberger2004,
	abstract = {The isotopes 251No and 253No were produced in nuclear reactions 206Pb( 48Ca,3n) 251No and 207Pb( 48Ca,2n) 253No. Radioactive decay of these isotopes and their daughter products has been investigated by means of α- and α-γ- spectroscopy. An isomeric state 251mNo, having a half-life of T1/2 = (0.93$\pm$0.06) s and decaying by emission of αparticles of Eα= (8665$\pm$8) keV was identified. The measured decay data allowed for the construction of partial level schemes for 251No, 247, 249Fm and 243, 245Cf and an extrapolation of energy systematics of single particle levels of N = 145, 147 and 149 isotones with even Z towards higher atomic numbers up to Z = 102.},
