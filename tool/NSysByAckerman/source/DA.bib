@article{Beiner1973,
	abstract = {The interpretation of the 183, 185Hg anomalous isotope shifts based
	on a sudden occurence of low-lying states belonging to bubble configurations
	is shown to be unrealistic. Moreover, using an extension of the energy
	density formalism in which the single quasi-particle structure of
	nuclei is taken into account we find that a) neither the neutron
	- nor the proton ground state density of all proposed bubble candidates
	presents any particular central depletion and b) for low-lying states
	bubble configurations cannot compete with usual ones except in the
	hypothetic cases of spherical nuclei with extremely large proton
	numbers Z ≳ 200.},
	author = {M. Beiner and R.J. Lombard},
	doi = {http://dx.doi.org/10.1016/0370-2693(73)90097-X},
	issn = {0370-2693},
