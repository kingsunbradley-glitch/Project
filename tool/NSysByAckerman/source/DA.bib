@article{BROSA1990,
	abstract = {Two models of nuclear exit channel reactions are examined: random neck rupture and multichannel fission. The foundations of both models are explained, and the algorithms for their usage are given. Ample experimental evidence for the validity of these models is presented. Especially fruitful is their synthesis. We now understand the properties of the fragments, which are produced in low-energy fission, much better than we did four years ago.},
