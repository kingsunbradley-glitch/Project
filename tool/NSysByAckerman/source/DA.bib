@article{ZhangZY2012,
	abstract = {With the recent commissioning of a gas-filled recoil separator at Institute of Modern Physics (IMP) in Lanzhou, the decay properties of 271Ds (Z = 110) were studied via the 208Pb(64Ni, n) reaction at a beam energy of 313.3 MeV. Based on the separator coupled with a position sensitive silicon strip detector, we carried out the energy-position-time correlation measurements for the implanted nucleus and its subsequent decay α's. One α-decay chain for 271Ds was established. The α energy and decay time of the 271Ds nucleus were measured to be 10.644 MeV and 96.8 ms, which are consistent with the values reported in the literature.},
