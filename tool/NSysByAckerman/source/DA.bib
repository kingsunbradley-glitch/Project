@article{Oganessian2017,
	abstract = {A fundamental outcome of modern nuclear microscopic theory is the prediction of the `islands of stability' in the region of hypothetical superheavy elements (SHEs). In a heavy nucleus, going through the large-scale deformation on the way to fission, the motion of single nucleons is coupled with the collective degrees of freedom of the whole system. The most striking effect of this coupling is obtained for the case of fission of the heaviest nuclei, whose existence is defined entirely by the nuclear structure, i.e. by the shell effect. From this point of view, the synthesis and study of properties of superheavy nuclei (SHN) is a direct way for checking the basic statements of the microscopic nuclear theory. On the nuclide map, SHN outline the border of the heaviest nuclear masses. SHN set the limits of the periodic system of chemical elements. The study of possible existence of SHN in nature offers a way for testing different scenarios of astrophysical nucleosynthesis. The paper elucidates experimental approaches, used for testing the theory predictions made about the SHN, and presents the results of the discovery of the `stability island' of SHEs.},
	author = {Yu Ts Oganessian and A Sobiczewski and G M Ter-Akopian},
	date-added = {2024-02-20 16:53:23 +0100},
	date-modified = {2024-02-20 16:55:42 +0100},
	doi = {10.1088/1402-4896/aa53c1},
	journal = {Physica Scripta},
	month = {jan},
	number = {2},
	pages = {023003},
	publisher = {IOP Publishing},
	title = {Superheavy nuclei: from predictions to discovery},
	url = {https://dx.doi.org/10.1088/1402-4896/aa53c1},
	volume = {92},
	year = {2017},
	bdsk-url-1 = {https://dx.doi.org/10.1088/1402-4896/aa53c1}}

@article{Walker2024,
	abstract = {The properties of K isomers are reviewed. Energies and decay hindrance factors are considered in detail for selected isomers in the {\$}{\$}A {$\backslash$}approx {\$}{\$} 160--190 region, focusing on pairing effects and the key K-mixing mechanisms that influence {\$}{\$}{$\backslash$}gamma {\$}{\$}-ray decay rates. The {\$}{\$}{$\backslash$}beta {\$}{\$}-decay of K isomers is studied, indicating that, far from the valley of {\$}{\$}{$\backslash$}beta {\$}{\$}stability, high-K {\$}{\$}{$\backslash$}beta {\$}{\$}-decaying isomers will populate high-K states in the daughter nuclei. The challenges of revealing predicted, but as-yet undiscovered, long-lived isomers in the neutron-rich {\$}{\$}N {$\backslash$}approx 116{\$}{\$}prolate--oblate shape transition region are highlighted, and the occurrence of oblate high-K isomers is discussed. The 2015 multi-quasiparticle K-isomer table of Kondev, Dracoulis, and Kib{\'e}di is updated.},
	author = {Walker, P. M. and Kondev, F. G.},
