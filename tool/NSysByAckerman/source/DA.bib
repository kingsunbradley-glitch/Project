@article{Lopez-Martens2025,
	abstract = {The study of the heaviest nuclei is not only an experimental challenge (due to the very low production cross sections involved), but it is also a theoretical one. Indeed, the combination of large Coulomb fields and high densities of single-particle states makes theoretical calculations difficult and leads to extreme model dependencies, such as for example the localisation of the so-called ``island of stability'' [1]. Moreover, recent experimental and theoretical studies have shed light on deficiencies of energy density functionals (EDF), which are used to describe nuclear properties across the entire nuclear chart [2], [3]. This suggests that further improvements of the EDF methods are necessary and that new reliable data are required to benchmark and constrain the theoretical models. In this talk, recent results on the structure of transfermium nuclei will be presented and discussed.},
	author = {A. Lopez-Martens and P. Brionnet and R. Chakma and K. Hauschild and K. Kessaci and O. Dorvaux and B. Gall and A.I. Svirikhin and A.V. Yeremin},
	date-added = {2025-07-07 17:36:04 +0200},
	date-modified = {2025-07-07 17:36:21 +0200},
	doi = {https://doi.org/10.1016/j.nuclphysa.2025.123201},
	issn = {0375-9474},
	journal = {Nuclear Physics A},
	pages = {123201},
	title = {Structure of the heaviest nuclei},
	url = {https://www.sciencedirect.com/science/article/pii/S0375947425001873},
	volume = {1063},
	year = {2025},
	bdsk-url-1 = {https://www.sciencedirect.com/science/article/pii/S0375947425001873},
	bdsk-url-2 = {https://doi.org/10.1016/j.nuclphysa.2025.123201}}

