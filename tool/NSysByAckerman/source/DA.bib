@article{Ahmad1975,
	abstract = {The half-life of the 254Es ground state was measured by following the decay of the daughter 250Bk (3·1 hr) γ-rays in radioactive equilibrium with 254Es. An isotopically enriched 254Es sample was used and the γ-rays were counted with a high resolution 25 cm3 Ge(Li) spectrometer. 137Cs activity, fixed to the 254Es sample, was used as an internal calibration source to correct for the variations in the source-to-detector geometry. The decay of the γ-ray spectrum was followed for 2 yr. A least-squares fit to the areas of the 989·0 and (1028·6 + 1031·8) keV photopeaks gave a half-life of 275·7 $\pm$0·5 d for 254Es.},
