@article{Bothe1928,
	abstract = {Zur Bestimmung von Ausbeuten bei der Atomzertr{\"u}mmerung wurden
	Versuche angestellt, bei welchen Polonium als$\alpha$-Strahlenquelle
	und ein mit H-Strahlen geeichter Spitzenz{\"a}hler zum Nachweis der
	Atomtr{\"u}mmer diente. Es zeigte sich, da{\ss} bei $\alpha$-Strahlenbombardement
	au{\ss}er den Atomtr{\"u}mmern und reflektierten $\alpha$-Teilchen
	noch die charakteristischen R{\"o}ntgenstrahlen der betreffenden
	Substanz sich bemerkbar machen k{\"o}nnen. Die praktische Ausschaltung
	dieser R{\"o}ntgenstrahlen gelingt durch passende Wahl der Gasf{\"u}llung
	des Z{\"a}hlers und durch Anwendung von Absorptionsfolien passender
	Ordnungszahl. Die hiernach f{\"u}r die Atomtr{\"u}mmer noch in Betracht
	kommenden Intensit{\"a}ten sind bei Be, C, Al und Fe so klein, da{\ss}
	sie mit den Resultaten der Wiener Forscher (Kirsch, Pettersson u.a.)
	nicht in Einklang zu bringen sind und f{\"u}r die Richtigkeit der
	Ergebnisse von Rutherford und Chadwick sprechen. Beim Kohlenstoff
	ergaben sich Anzeichen, da{\ss} die Reflexion der$\alpha$-Teilchen
	unter 127{\textdegree} st{\"a}rker ist als nach der Rutherfordschen
	Theorie zu erwarten. Die Ergebnisse fr{\"u}her mitgeteilter Vorversuche
	wurden durch {\"a}hnliche Versuche mit st{\"a}rkerer Strahlenquelle
	hinsichtlich der Ausbeuten und Reichweiten der Atomtr{\"u}mmer pr{\"a}zisiert.
	Beim Bor treten zwei Gruppen von Atomtr{\"u}mmern verschiedener Reichweite
	auf, welche vermutlich den beiden Isotopen zuzuordnen sind. Die M{\"o}glichkeit,
	da{\ss} Szintillationsz{\"a}hlungen durch bisher unbekannte$\beta$-Strahleneffekte
	gef{\"a}lscht werden k{\"o}nnten, wird diskutiert.},
	author = {Bothe, W. and Fr{\"a}nz, H.},
	doi = {10.1007/BF01327817},
	issn = {0044-3328},
	journal = {Z. f. Physik},
	number = {1},
	owner = {Ackerman},
	pages = {1--26},
	timestamp = {2016.10.28},
	title = {Atomtr{\"u}mmer, reflektierte $\alpha$-Teilchen und durch $\alpha$-Strahlen erregte R{\"o}ntgenstrahlen},
	url = {http://dx.doi.org/10.1007/BF01327817},
	volume = {49},
	year = {1928},
	bdsk-url-1 = {http://dx.doi.org/10.1007/BF01327817}}

