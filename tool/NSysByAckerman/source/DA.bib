@article{Ahmad1977a,
	abstract = {The half-life of the nuclide 252Es has been measured by following the decay of the 785.1 keV γ-ray associated with its electron capture decay. The 252Es sample used in this study was produced by 249Bk(α, n) reaction. The γ-ray spectrum of a chemically purified 252Es sample was measured with a high-resolution 25 cm3 Ge(Li) spectrometer. 137Cs activity, fixed to the 252Es sample, was used as an internal calibration source to correct for variations in the source-detector geometry. The decay of the γ-ray spectrum was followed for three years. A least-squares fit to the areas of the 785.1 keV photopeaks gave a half-life of 471.7$\pm$1.9d for 252Es decay. This half-life indicates that 252Es is the longest-lived einsteinium isotope.},
	author = {Ahmad, Irshad and Wagner, Frank},
