@article{Hessberger2005,
	abstract = {The decay of odd-mass mendelevium isotopes ( A = 247-255) has been studied by means of α-γspectroscopy. Strong evidence for a small αbranch in the decay of 253Md was found. γlines in coincidence with α-decays of 247, 249, 251, 253Md have been observed for the first time. Levels in the einsteinium daughter nuclei were assigned on the basis of α-γcoincidence measurements. An energy systematics of the 7/2-{$[$}514{$]$} Nilsson level could be established, showing a correlation with the deformation parameter β2 of the corresponding nuclei. The results are compared with theoretical predictions},
